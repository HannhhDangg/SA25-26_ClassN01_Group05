{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "#707070",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HR Management microservices health and performance dashboard.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["hr", "microservices", "health"],
  "templating": {
    "list": [
      {
        "current": {"text": "production", "value": "production"},
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [],
        "query": "label_values(up, env)",
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": {"text": "attendance_service", "value": "attendance_service"},
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [],
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": {"text": "1h", "value": "1h"},
        "hide": 0,
        "includeAll": false,
        "label": "Time Range",
        "multi": false,
        "name": "timerange",
        "options": [
          {"text": "15m", "value": "15m"},
          {"text": "1h", "value": "1h"},
          {"text": "6h", "value": "6h"},
          {"text": "12h", "value": "12h"},
          {"text": "24h", "value": "24h"}
        ],
        "query": "1h",
        "refresh": 1,
        "regex": "",
        "type": "constant"
      }
    ]
  },
  "time": {
    "from": "now-${timerange}",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "HR Management Microservices Health",
  "uid": "hrm-microservices-health",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Row 1 — Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "id": 1,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Services UP",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(up{job=~\"$service\", env=~\"$environment\"}) or vector(0)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Total Request Rate",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(rate(http_requests_total{job=~\"$service\", env=~\"$environment\"}[1m])) or vector(0)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Error Rate %",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 5, "color": "red"}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\", job=~\"$service\", env=~\"$environment\"}[1m])) / sum(rate(http_requests_total{job=~\"$service\", env=~\"$environment\"}[1m])) * 100 or vector(0)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "System P99 Latency",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"$service\", env=~\"$environment\"}[5m])))", "refId": "A"}]
    },
    {
      "type": "row",
      "title": "Row 2 — Per Service Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false,
      "id": 6,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Service",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 6},
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(http_requests_total{job=~\"$service\", env=~\"$environment\"}[1m])) by (job)", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Service",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 6},
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\", job=~\"$service\", env=~\"$environment\"}[1m])) by (job) / sum(rate(http_requests_total{job=~\"$service\", env=~\"$environment\"}[1m])) by (job) * 100", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "gauge",
      "title": "Service P95 Response Time",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 13},
      "id": 9,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$service\", env=~\"$environment\"}[5m])))", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 1, "color": "red"}]}}}
    },
    {
      "type": "table",
      "title": "Top 5 Slowest Endpoints",
      "gridPos": {"h": 5, "w": 18, "x": 6, "y": 13},
      "id": 10,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "topk(5, sum by (job, route) (rate(http_request_duration_seconds_sum{job=~\"$service\", env=~\"$environment\"}[5m]) / rate(http_request_duration_seconds_count{job=~\"$service\", env=~\"$environment\"}[5m])))", "refId": "A"}],
      "options": {"showHeader": true}
    },
    {
      "type": "row",
      "title": "Row 3 — Infrastructure",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "collapsed": false,
      "id": 11,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU Usage per Host",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 19},
      "id": 12,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "100 - avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100", "legendFormat": "{{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 19},
      "id": 13,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100", "legendFormat": "{{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "barchart",
      "title": "Disk I/O",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 19},
      "id": 14,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "rate(node_disk_read_bytes_total[5m]) + rate(node_disk_written_bytes_total[5m])", "legendFormat": "{{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "Network Traffic In/Out",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 19},
      "id": 15,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "in {{instance}}", "refId": "A"},
        {"expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "out {{instance}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "row",
      "title": "Row 4 — Database",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "collapsed": false,
      "id": 16,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Health",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 26},
      "id": 17,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "pg_up{env=~\"$environment\"} or vector(0)", "legendFormat": "{{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "MongoDB Status",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 26},
      "id": 18,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "mongodb_up{env=~\"$environment\"} or vector(0)", "legendFormat": "mongodb up", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "gauge",
      "title": "Redis Memory Usage %",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 32},
      "id": 19,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}}}
    },
    {
      "type": "timeseries",
      "title": "Redis Command Latency P95",
      "gridPos": {"h": 6, "w": 18, "x": 6, "y": 32},
      "id": 20,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, instance) (rate(redis_commands_latencies_usec_bucket{job=\"redis\", env=~\"$environment\"}[5m]))) / 1e6", "legendFormat": "{{instance}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "row",
      "title": "Row 5 — Kong API Gateway",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "collapsed": false,
      "id": 21,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Kong Requests by Route",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 39},
      "id": 22,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(kong_http_requests_total{env=~\"$environment\"}[1m])) by (route)", "legendFormat": "{{route}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat",
      "title": "Kong Rate Limited Requests",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 39},
      "id": 23,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 10, "color": "yellow"}, {"value": 50, "color": "red"}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(rate(kong_http_requests_total{env=~\"$environment\", code=~\"429\"}[1m])) or vector(0)", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "JWT Auth Failures",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 39},
      "id": 24,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(kong_http_requests_total{env=~\"$environment\", code=~\"401|403\"}[1m])) by (route) or vector(0)", "legendFormat": "{{route}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "statusmap",
      "title": "Service Status Map",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 45},
      "id": 25,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "probe_success or vector(0)", "refId": "A"}],
      "options": {"colorMode": "value", "sortBy": "name"}
    }
  ]
}
